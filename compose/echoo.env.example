# Echoo environment variables – cloud mode
# Run start.py – it fills in everything automatically.
#
# To generate APP_KEY manually:
#   python -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
APP_KEY=

# AdonisJS database settings
DB_HOST=echoo-db
DB_PORT=5432
DB_USER=postgres
# Choose any password – must match POSTGRES_PASSWORD below.
DB_PASSWORD=
DB_DATABASE=ECHOO

# PostgreSQL container settings (must match DB_* values above)
POSTGRES_DB=ECHOO
POSTGRES_USER=postgres
POSTGRES_PASSWORD=