# Echoo environment variables – cloud mode
# Copy this file to echoo.env and fill in the values.

APP_KEY=                          # required: any random 32-character string

DB_HOST=echoo-db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=                      # required: choose a strong password
DB_DATABASE=ECHOO

ECHOO_DB_NAME=ECHOO
ECHOO_DB_USER=postgres
ECHOO_DB_PASSWORD=                # same as DB_PASSWORD