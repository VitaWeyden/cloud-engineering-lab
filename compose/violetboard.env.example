# Violet-board environment variables – cloud mode
# Run start.py – it fills in everything automatically.
#
# To generate APP_KEY manually:
#   python -c "import secrets, base64; print('base64:' + base64.b64encode(secrets.token_bytes(32)).decode())"
APP_KEY=

APP_NAME=VioletBoard
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8000

# Laravel database settings
DB_CONNECTION=pgsql
DB_HOST=violetboard-db
DB_PORT=5432
DB_DATABASE=violetboard
DB_USERNAME=postgres
# Choose any password – must match POSTGRES_PASSWORD below.
DB_PASSWORD=

# PostgreSQL container settings (must match DB_* values above)
POSTGRES_DB=violetboard
POSTGRES_USER=postgres
POSTGRES_PASSWORD=