# Violet-board environment variables – cloud mode
# Copy this file to violetboard.env and fill in the values.

APP_NAME=VioletBoard
APP_ENV=production
APP_KEY=                          # required: base64:... format (php artisan key:generate --show)
APP_DEBUG=false
APP_URL=http://localhost:8000

DB_CONNECTION=pgsql
DB_HOST=violetboard-db
DB_PORT=5432
DB_DATABASE=violetboard
DB_USERNAME=postgres
DB_PASSWORD=                      # required: choose a strong password

VIOLETBOARD_DB_NAME=violetboard
VIOLETBOARD_DB_USER=postgres
VIOLETBOARD_DB_PASSWORD=          # same as DB_PASSWORD